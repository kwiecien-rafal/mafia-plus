---
import type { Character } from "../data/characters";
import { abilityTypeLabels, cardRank, cardSuit, factions } from "../data/characters";
import { ui } from "../data/content";
import T from "./T.astro";

interface Props {
  character: Character;
}
const { character } = Astro.props;

const faction = factions[character.faction];
const factionClasses = faction.style;
const suit = cardSuit(character.card);
const rank = cardRank(character.card);
---

<div
  class="flip group relative h-[22rem] cursor-pointer select-none rounded-2xl outline-none focus-visible:ring-2 focus-visible:ring-gold/70"
  data-flipped="false"
  role="button"
  tabindex="0"
  aria-label={`${character.name.pl} / ${character.name.en}`}
>
  <!-- Frosted panel lives outside the 3D flip: a perspective/transform ancestor
       blocks backdrop-filter from reaching the page, so the blur must sit here,
       behind the (now transparent) faces, to match every other panel. -->
  <div class="absolute inset-0 rounded-2xl bg-ink-card/75 shadow-xl shadow-black/40 backdrop-blur-md"></div>

  <div class="flip-stage absolute inset-0">
    <div class="flip-inner relative h-full w-full">
      <!-- FRONT -->
      <article
        class={`flip-face absolute inset-0 flex flex-col rounded-2xl border p-5 transition-colors ${factionClasses.border} ${factionClasses.ring}`}
      >
        <header class="flex items-start justify-between">
          <div class={`font-display text-2xl leading-none ${factionClasses.text}`}>
            <span>{rank}</span><span class="ml-0.5">{suit}</span>
          </div>
          <span class={`inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-[0.65rem] uppercase tracking-widest text-muted ${factionClasses.border}`}>
            <span class={`h-1.5 w-1.5 rounded-full ${factionClasses.dot}`}></span>
            <T text={faction.name} />
          </span>
        </header>

        <div class="pointer-events-none flex flex-1 items-center justify-center">
          <span class={`font-display text-[7rem] leading-none opacity-10 ${factionClasses.text}`}>{suit}</span>
        </div>

        <div class="space-y-3">
          <h3 class="font-display text-xl leading-tight text-bone">
            <T text={character.name} />
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {character.abilityTypes.map((t) => (
              <span class="rounded-md bg-white/5 px-2 py-0.5 text-[0.65rem] uppercase tracking-wide text-muted">
                <T text={abilityTypeLabels[t]} />
              </span>
            ))}
          </div>
          <p class="text-[0.7rem] text-muted/70">
            <T text={ui.flipHint} /> ↻
          </p>
        </div>
      </article>

      <!-- BACK -->
      <article
        class={`flip-face flip-back absolute inset-0 flex flex-col rounded-2xl border p-5 ${factionClasses.border}`}
      >
        <h3 class={`font-display text-lg leading-tight ${factionClasses.text}`}>
          <T text={character.name} />
        </h3>
        <div class="mt-2 flex-1 overflow-y-auto pr-1 text-sm leading-relaxed text-bone/90">
          <T text={character.ability} as="p" />
          <p class="mt-3 italic text-muted">
            <T text={character.flavor} />
          </p>
          {character.note && (
            <p class="mt-3 border-t border-white/10 pt-2 text-xs text-muted/80">
              <T text={character.note} />
            </p>
          )}
        </div>
        <footer class="mt-3 flex items-center justify-between border-t border-white/10 pt-2 text-xs text-muted">
          <span><T text={ui.cardLabel} />: <span class={factionClasses.text}>{(character.cards ?? [character.card]).join(" · ")}</span></span>
          <span class="opacity-70">↻</span>
        </footer>
      </article>
    </div>
  </div>
</div>
