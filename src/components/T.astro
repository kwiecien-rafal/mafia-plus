---
// Bilingual inline text. Renders both languages (CSS shows the active one) and
// applies the shared inline-markdown subset — bold, italic, underline — via
// inline.ts, the same markup the rulebook serializer passes through verbatim.
import type { Bilingual } from "../data/characters";
import { inlineToHtml } from "../data/inline";

interface Props {
  text: Bilingual;
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const { text, as = "span", class: className } = Astro.props;
const Tag = as as any;
---

<Tag class={className}><span data-l="pl" set:html={inlineToHtml(text.pl)} /><span data-l="en" set:html={inlineToHtml(text.en)} /></Tag>
