---
import T from "./T.astro";
import type { RuleSection } from "../data/content";

interface Props {
  section: RuleSection;
}
const { section } = Astro.props;
---

<div data-rules-card class="rounded-2xl border border-white/10 bg-ink-card/50 p-6">
  <h3 class="font-display text-xl text-gold"><T text={section.heading} /></h3>
  <div class="mt-3 space-y-3 text-sm leading-relaxed text-bone/85">
    {section.blocks.map((b) => (
      "list" in b ? (
        <ul class="list-disc space-y-1.5 pl-5 marker:text-gold/60">
          {b.list.map((li) => <T text={li} as="li" />)}
        </ul>
      ) : (
        <T text={b.p} as="p" />
      )
    ))}
  </div>
  {section.example && (
    <div class="mt-4 space-y-1.5 rounded-xl border border-white/10 bg-black/30 p-4 text-xs italic text-muted">
      {section.example.map((line) => <T text={line} as="p" />)}
    </div>
  )}
  {section.footnotes && (
    <div class="mt-4 space-y-1 text-xs italic text-muted/80">
      {section.footnotes.map((f) => <T text={f} as="p" />)}
    </div>
  )}
</div>
